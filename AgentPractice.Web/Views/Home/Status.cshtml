@model AgentPractice.Web.Models.StatusSummary
@{
    ViewData["Title"] = "Service Status";
}

<div class="container py-4">
    <h1 class="mb-3">Service Status</h1>
    <p class="mb-1"><strong>Service:</strong> @Model.Service</p>
    <p class="mb-1"><strong>Status:</strong> @Model.Status</p>
    <p class="mb-3"><strong>Timestamp (UTC):</strong> @Model.TimestampUtc.ToString("u")</p>
    <p><a asp-controller="Home" asp-action="Index">Back to Home</a></p>
</div>
