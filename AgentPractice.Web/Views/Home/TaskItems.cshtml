@{
    ViewData["Title"] = "Task Items";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h1 class="h3 mb-0">Task Items</h1>
            <span class="badge text-bg-primary">Create + View</span>
        </div>

        <p class="text-muted">This page creates and loads task items using <code>/api/TaskItems</code>.</p>

        <form id="task-item-create-form" class="card shadow-sm mb-3" novalidate>
            <div class="card-body">
                <label for="task-item-title" class="form-label">New task title</label>
                <div class="input-group">
                    <input
                        id="task-item-title"
                        name="title"
                        type="text"
                        class="form-control"
                        placeholder="Enter a task title"
                        autocomplete="off"
                        maxlength="200" />
                    <button id="task-item-add-button" type="submit" class="btn btn-primary">Add</button>
                </div>
            </div>
        </form>

        <div id="task-item-create-success" class="alert alert-success d-none" role="status" aria-live="polite"></div>
        <div id="task-item-create-error" class="alert alert-danger d-none" role="alert"></div>

        <div id="task-items-filter" class="d-flex align-items-center gap-2 mb-3" role="group" aria-label="Filter task items">
            <span class="text-muted small">Show:</span>
            <button id="task-items-filter-all" type="button" class="btn btn-sm btn-outline-secondary active" data-task-filter="all" aria-pressed="true">All</button>
            <button id="task-items-filter-open" type="button" class="btn btn-sm btn-outline-secondary" data-task-filter="open" aria-pressed="false">Open</button>
            <button id="task-items-filter-done" type="button" class="btn btn-sm btn-outline-secondary" data-task-filter="done" aria-pressed="false">Done</button>
        </div>

        <div class="mb-3">
            <label for="task-items-search" class="form-label mb-1">Search by title</label>
            <div class="input-group">
                <input
                    id="task-items-search"
                    type="search"
                    class="form-control"
                    placeholder="Type to filter tasks"
                    autocomplete="off"
                    maxlength="200" />
                <button id="task-items-clear-search" type="button" class="btn btn-outline-secondary d-none">Clear Search</button>
            </div>
        </div>

        <div id="task-items-loading" class="alert alert-secondary" role="status" aria-live="polite">
            Loading task items...
        </div>

        <div id="task-items-error" class="alert alert-danger d-none" role="alert"></div>

        <div id="task-items-count" class="text-muted small mb-2 d-none" role="status" aria-live="polite"></div>

        <div id="task-items-empty" class="alert alert-info d-none" role="status" aria-live="polite">
            No task items found.
        </div>

        <div id="task-items-list" class="list-group shadow-sm d-none" aria-live="polite"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/task-items.js" asp-append-version="true"></script>
}
